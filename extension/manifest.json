{
  "manifest_version": 3,
  "name": "CAT Collector",
  "version": "1.2.1",
  "description": "Captura peças do SIS 2.0 e envia para o CAT Smart Parts.",

  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting"
  ],

  "host_permissions": [
    "https://sis2.cat.com/*",
    "http://localhost:8080/*",
    "http://127.0.0.1:8080/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_title": "CAT Collector",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },

  "content_scripts": [
    {
      "matches": [
        "https://sis2.cat.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}