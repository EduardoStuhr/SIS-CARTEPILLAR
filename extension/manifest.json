{
  "manifest_version": 3,
  "name": "CAT Collector",
  "version": "1.2.0",
  "description": "Captura peças do SIS 2.0 e envia para o CAT Smart Parts.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://sis2.cat.com/*",
    "http://localhost:8080/*",
    "http://127.0.0.1:8080/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}